# Build Configuration for Money Manager App
# This file contains all build settings used by Makefile

# Application ID
APP_ID=com.aminmart.moneymanager

# Version Info
VERSION_CODE=1
VERSION_NAME=1.0.0

# SDK Versions
MIN_SDK_VERSION=24
TARGET_SDK_VERSION=33
COMPILE_SDK_VERSION=33

# Kotlin Version
KOTLIN_VERSION=1.9.20

# Android Build Tools Version
BUILD_TOOLS_VERSION=33.0.2

# App Name
APP_NAME=Money Manager

# Package name for Kotlin files
PACKAGE_NAME=com/aminmart/moneymanager

# Output APK name
OUTPUT_APK=money-manager.apk
OUTPUT_APK_SIGNED=money-manager-signed.apk
